[core]
    editor = nvim
    excludesfile = /Users/nolinmcfarland/.gitignore

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
    rebase = true

[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f

[alias]
    # Status
    s = status -sb
    
    # Switch
    sw = switch
    nb = switch -c
    go = !sh -c '[[ "$(git branch | grep -i $1 | wc -l)" -eq "1" ]] && git switch "$(git branch | grep -i $1 | tr -d [:space:])" || echo "\\\"$1\\\" matches zero or multiple branches"' -
    
    # Branch
    b = branch --sort=-committerdate
    db = branch -D
    rn = branch -m
    cb = "!b=$(git rev-parse --abbrev-ref HEAD) && echo \"$b\" | pbcopy && echo \"Copied \\\"$b\\\" to clipboard\""
    mb = !git branch -vv | grep ': gone]' | awk '{print $1}'
    sweep = "!f() { \
        auto=false; \
        for branch in $(git mb); do \
            if [ \"$auto\" = true ]; then \
                git db \"$branch\"; \
                continue; \
            fi; \
            read -p \"\nDelete $branch? (y/N/a) \" ans; \
            case \"$ans\" in \
                y|Y) git db \"$branch\" ;; \
                a|A) auto=true; git db \"$branch\" ;; \
                *) ;; \
            esac; \
        done; \
    }; f"

    # Stash
    ss = stash save
    sp = stash pop
    sl = stash list
    sa = stash apply
    sd = stash drop

    # Add
    a = add
    aa = add --all
    ap = add --patch
    ai = add --interactive

    # Commit
    c = commit --verbose
    ca = commit --amend --no-edit

    # Push
    pu = push
    puf = push --force-with-lease

    # Pull
    pl = pull --rebase --autostash
 
    # Cherrypick
    cp = cherry-pick

    # Rebase
    r = rebase
    ri = rebase --interactive
    rc = rebase --continue
    ra = rebase --abort
    rs = rebase --skip

    # Diff
    d = diff -w
    ds = diff --staged
    dt = difftool
    
    # Merge
    m = merge
    mt = mergetool

    # Log
    l = log --oneline
    lg = log --oneline --graph
    
    # Misc
    undo = reset HEAD~1
    unstage = restore --staged
    alias = !git config -l | grep alias | cut -c 7-

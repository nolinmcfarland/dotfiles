[
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "terminal_panel::Toggle",
    },
  },
  {
    "bindings": {
      "ctrl-y": "menu::Confirm",
    },
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCompletion",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-[": "pane::ActivatePreviousItem",
      "ctrl-]": "pane::ActivateNextItem",
    },
  },
]
